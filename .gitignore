# ===================================================================
# Unity 6.3 URP 3D (PC) - .gitignore
# Works with project in subfolder structure
# ===================================================================

# -----------------------------------------------
# Unity generated folders & files
# -----------------------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# -----------------------------------------------
# Memory Profiler snapshots
# -----------------------------------------------
[Mm]emoryCaptures/

# -----------------------------------------------
# Recordings (Unity Recorder / screen captures)
# -----------------------------------------------
[Rr]ecordings/

# -----------------------------------------------
# Asset Import Worker database
# -----------------------------------------------
[Aa]ssets/AssetStoreTools*

# -----------------------------------------------
# Auto-generated VS / Rider solution and project files
# -----------------------------------------------
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# -----------------------------------------------
# Unity3D generated meta files (for OS files)
# -----------------------------------------------
*.pidb.meta
*.pdb.meta
*.mdb.meta

# -----------------------------------------------
# Builds - PC standalone
# -----------------------------------------------
*.apk
*.aab
*.unitypackage
*.app

# Windows build artifacts
*.exe
!Assets/Plugins/**/*.dll

# -----------------------------------------------
# Crashlytics / crash reports
# -----------------------------------------------
crashlytics-build.properties
sysinfo.txt

# -----------------------------------------------
# Gradle (not needed for PC but just in case)
# -----------------------------------------------
[Aa]ssets/Plugins/Android/gradleOut/

# -----------------------------------------------
# Addressables (generated)
# -----------------------------------------------
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/*

# -----------------------------------------------
# TextMeshPro (auto-generated; re-import if needed)
# -----------------------------------------------
[Aa]ssets/[Tt]ext[Mm]esh Pro/

# -----------------------------------------------
# Plastic SCM (Unity VCS)
# -----------------------------------------------
[Aa]ssets/Plugins/PlasticSCM*
ignore.conf
*.private.0
*.private

# -----------------------------------------------
# IDE specific
# -----------------------------------------------

# Visual Studio
.vs/

# JetBrains Rider
.idea/
*.DotSettings.user

# VS Code
.vscode/

# -----------------------------------------------
# OS generated files
# -----------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory

# -----------------------------------------------
# Shader cache & compiled variants
# -----------------------------------------------
[Ss]hader[Cc]ache/

# -----------------------------------------------
# Code coverage results
# -----------------------------------------------
[Cc]ode[Cc]overage/

# -----------------------------------------------
# Burst AOT cache
# -----------------------------------------------
[Ss]treamingAssets/burst.metadata
